{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "anonymous": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "NTK Face Finder",
        "supportEmail": "feaiccws@gmail.com"
      }
    }
  },
  "database": {
    "rules": "database.rules.json"
  }
}
